{
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    }
  },
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "receipt-ochre.vercel.app"
        }
      ],
      "destination": "https://receipts.cafe/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "receipt-ochre.vercel.app"
        }
      ],
      "destination": "https://receipts.cafe/:path*",
      "permanent": true
    }
  ]
}
